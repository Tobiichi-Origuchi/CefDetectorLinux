{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CefDetector",
  "version": "0.1.6",
  "identifier": "com.cefdetector.linux",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CEF Detector Linux",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "shortDescription": "Check how many CEFs are on your Linux.",
    "category": "Utility",
    "active": true,
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "fd-find"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "fd-find"
        ]
      }
    },
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
