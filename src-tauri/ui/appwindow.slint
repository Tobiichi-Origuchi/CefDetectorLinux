import { ScrollView } from "std-widgets.slint";

export struct AppItem {
    file: string,
    app_type: string,
    size_str: string,
    is_running: bool,
    is_dir: bool,
    icon: image,
    filename: string,
}

export component AppWindow inherits Window {
    title: "CEF Detector Linux";
    width: 800px;
    height: 600px;
    
    in property <string> search_status: "正在全盘搜索 CEF 应用，请耐心等待...";
    in property <[AppItem]> apps: [];
    callback open_path(string, bool);
    callback open_repo();

    Rectangle {
        width: 100%;
        height: 100%;
        Image {
            source: @image-url("background.webp");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }

        VerticalLayout {
            padding-top: root.height * 0.21;
            
            Text {
                text: root.search_status;
                font-size: 24px;
                font-weight: 700;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            HorizontalLayout {
                padding-left: root.width * 0.10;
                padding-right: root.width * 0.10;
                padding-top: root.height * 0.05;
                
                sv := ScrollView {
                    width: 100%;
                    height: root.height * 0.60;
                    property <int> cols: Math.max(1, Math.floor(self.width / 104px));
                    viewport-width: self.width;
                    viewport-height: Math.ceil(root.apps.length / self.cols) * 126px;

                    for app[i] in root.apps : Rectangle {
                        x: Math.mod(i, sv.cols) * 104px + 6px;
                        y: Math.floor(i / sv.cols) * 126px + 6px;
                        width: 92px;
                        height: 114px;
                        border-radius: 4px;
                        background: ta.has-hover ? rgba(255, 255, 255, 0.55) : rgba(255, 255, 255, 0.3);
                        border-width: 1px;
                        border-color: ta.has-hover ? rgba(255, 255, 255, 0.55) : rgba(255, 255, 255, 0.3);

                        ta := TouchArea {
                            clicked => { root.open_path(app.file, app.is_dir); }
                        }

                        VerticalLayout {
                            padding-top: 12px;
                            padding-bottom: 12px;
                            padding-left: 6px;
                            padding-right: 6px;
                            alignment: start;
                            spacing: 4px;

                            HorizontalLayout {
                                alignment: center;
                                Image {
                                    source: app.icon;
                                    width: 36px;
                                    height: 36px;
                                }
                            }
                            Text {
                                text: app.filename;
                                font-size: 14px;
                                font-weight: 700;
                                color: black;
                                horizontal-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: app.app_type;
                                font-size: 10px;
                                color: app.is_running ? #4caf50 : (app.app_type == "unknown" ? #000000 : #2196f3);
                                horizontal-alignment: center;
                            }
                            Text {
                                text: app.size_str;
                                font-size: 9px;
                                color: rgba(0, 0, 0, 0.84);
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        TouchArea {
            x: 10px;
            y: root.height - 30px;
            width: link_text.width;
            height: link_text.height;
            clicked => { root.open_repo(); }
            
            link_text := Text {
                text: "Repo: github.com/Tobiichi-Origuchi/CefDetectorLinux (求个STAR!)";
                color: parent.has-hover ? #ffffff : rgba(255, 255, 255, 0.8);
                font-size: 12px;
            }
        }
    }
}
