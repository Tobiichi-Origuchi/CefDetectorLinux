export struct AppItem {
    file: string,
    app_type: string,
    size_str: string,
    is_running: bool,
    is_dir: bool,
    icon: image,
    filename: string,
    raw_size: int,
}

component AppCard inherits Rectangle {
    in property <image> icon;
    in property <string> filename;
    in property <string> app_type;
    in property <string> size_str;
    in property <bool> is_running;
    in property <bool> is_dir;
    in property <string> file;
    callback clicked();

    width: 94px;
    height: 116px;
    border-radius: 4px;
    property <color> card-bg: ta.has-hover ? rgba(255, 255, 255, 0.55) : rgba(255, 255, 255, 0.3);
    background: root.card-bg;
    border-width: 1px;
    border-color: root.card-bg;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding-top: 12px;
        padding-bottom: 12px;
        padding-left: 6px;
        padding-right: 6px;
        alignment: center;
        spacing: 2px;

        HorizontalLayout {
            alignment: center;
            Image {
                source: root.icon;
                width: 36px;
                height: 36px;
            }
        }

        Text {
            text: root.filename;
            font-size: 11px;
            font-weight: 700;
            color: root.is_running ? #4caf50 : black;
            horizontal-alignment: center;
            overflow: elide;
            max-width: 76px;
        }

        Text {
            text: root.app_type;
            font-size: 10px;
            color: root.is_running ? #4caf50 : #000000;
            horizontal-alignment: center;
        }

        Text {
            text: root.size_str;
            font-size: 9px;
            color: rgba(0, 0, 0, 0.84);
            horizontal-alignment: center;
        }
    }
}

export component AppWindow inherits Window {
    title: "CEF Detector Linux";
    icon: @image-url("../icons/128x128.png");
    preferred-width: 800px;
    preferred-height: 600px;

    in property <string> search_status: "正在全盘搜索 CEF 应用，请耐心等待...";
    in property <bool> search_done: false;
    in property <[AppItem]> apps: [];
    callback open_path(string, bool);
    callback open_repo();

    property <length> cell_w: 106px; // card + margin
    property <length> cell_h: 128px;
    property <length> scroll_w: root.width * 0.80;
    property <int> cols: Math.max(1, Math.floor(scroll_w / cell_w));
    property <int> rows: Math.ceil(root.apps.length / cols);

    Rectangle {
        width: 100%;
        height: 100%;

        Image {
            source: @image-url("background.webp");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }

        Text {
            x: 0;
            y: root.height * 0.21;
            width: root.width;
            font-size: 18px;
            font-weight: 700;
            color: root.search_done ? #2196f3 : #ffffff;
            horizontal-alignment: center;
            text: root.search_status;
        }

        flick := Flickable {
            x: root.width * 0.10;
            y: root.height * 0.30;
            width: root.scroll_w - 16px; // reserve space for scrollbar
            height: root.height * 0.60;
            viewport-width: self.width;
            viewport-height: root.rows * root.cell_h;

            for app[i] in root.apps: AppCard {
                x: Math.mod(i, root.cols) * root.cell_w + 6px;
                y: Math.floor(i / root.cols) * root.cell_h + 6px;
                icon: app.icon;
                filename: app.filename;
                app_type: app.app_type;
                size_str: app.size_str;
                is_running: app.is_running;
                is_dir: app.is_dir;
                file: app.file;
                clicked => {
                    root.open_path(app.file, app.is_dir);
                }
            }
        }

        if flick.viewport-height > flick.height: Rectangle {
            x: flick.x + flick.width + 8px;
            y: flick.y;
            width: 8px;
            height: flick.height;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.1);

            scroll_ta := TouchArea {
                width: 100%;
                height: 100%;

                property <length> pressed_vp_y;
                property <bool> is_dragging: false;

                pointer-event(event) => {
                    // mouse-move handled by `moved` callback below
                    if (event.kind != PointerEventKind.down && event.kind != PointerEventKind.up) {
                        return;
                    }
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        if (self.mouse-y >= thumb.y && self.mouse-y <= thumb.y + thumb.height) {
                            self.is_dragging = true;
                            self.pressed_vp_y = flick.viewport-y;
                        } else {
                            self.is_dragging = false;
                        }
                    }
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        self.is_dragging = false;
                    }
                }

                moved => {
                    if (self.is_dragging && self.pressed) {
                        let max_scroll_y = parent.height - thumb.height;
                        if (max_scroll_y > 0px) {
                            let ratio = (flick.viewport-height - flick.height) / max_scroll_y;
                            let dy = self.mouse-y - self.pressed-y;
                            let new_vp_y = self.pressed_vp_y - dy * ratio;
                            flick.viewport-y = Math.min(0px, Math.max(flick.height - flick.viewport-height, new_vp_y));
                        }
                    }
                }
            }

            thumb := Rectangle {
                width: 100%;
                border-radius: 4px;
                background: scroll_ta.has-hover ? rgba(255, 255, 255, 0.55) : rgba(255, 255, 255, 0.3);
                border-width: 1px;
                border-color: scroll_ta.has-hover ? rgba(255, 255, 255, 0.55) : rgba(255, 255, 255, 0.3);

                property <length> track_h: parent.height;
                property <length> vp_h: flick.viewport-height;
                height: Math.max(20px, self.track_h * (flick.height / self.vp_h));
                y: (flick.viewport-y <= 0) ? (-flick.viewport-y / (self.vp_h - flick.height)) * (self.track_h - self.height) : 0;
            }
        }

        TouchArea {
            x: 10px;
            y: root.height - 32px;
            width: link_text.width;
            height: link_text.height;
            mouse-cursor: pointer;
            clicked => {
                root.open_repo();
            }

            link_text := Text {
                text: "Repo: github.com/Tobiichi-Origuchi/CefDetectorLinux (求个STAR!)";
                color: parent.has-hover ? #ffffff : rgba(255, 255, 255, 0.8);
                font-size: 12px;
            }
        }
    }
}
